{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "User profile information including role and verification status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "school": { "type": "string" },
        "photoUrl": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["admin", "teacher"] },
        "isVerified": { "type": "boolean" }
      },
      "required": ["uid", "email", "name", "role", "isVerified"]
    },
    "News": {
      "title": "News Article",
      "description": "News article with image and content.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isApproved": { "type": "boolean" }
      },
      "required": ["title", "content", "authorId", "authorName", "createdAt", "isApproved"]
    },
    "Event": {
      "title": "Event/Workshop",
      "description": "Workshop or event details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isApproved": { "type": "boolean" }
      },
      "required": ["title", "description", "date", "location", "authorId", "authorName", "createdAt", "isApproved"]
    },
    "Material": {
      "title": "Educational Material",
      "description": "Documents and learning materials.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isApproved": { "type": "boolean" }
      },
      "required": ["title", "fileUrl", "authorId", "authorName", "createdAt", "isApproved"]
    },
    "Settings": {
      "title": "Site Settings",
      "description": "Global site settings like vision, mission, and background.",
      "type": "object",
      "properties": {
        "vision": { "type": "string" },
        "mission": { "type": "array", "items": { "type": "string" } },
        "heroBackground": { "type": "string", "format": "uri" },
        "history": { "type": "string" }
      },
      "required": ["vision", "mission", "heroBackground"]
    },
    "Staff": {
      "title": "Staff Member",
      "description": "Organization structure member.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "position": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "order": { "type": "integer" }
      },
      "required": ["name", "position", "order"]
    },
    "Documentation": {
      "title": "Documentation",
      "description": "Activity documentation with photos and descriptions.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isApproved": { "type": "boolean" }
      },
      "required": ["title", "description", "imageUrls", "authorId", "authorName", "createdAt", "isApproved"]
    },
    "BestPractice": {
      "title": "Best Practice",
      "description": "Collaborative space for sharing teaching strategies and innovations.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "driveUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string", "enum": ["Metode Pembelajaran Kreatif", "Media Ajar Inovatif", "Administrasi & Modul", "Video Praktik Baik"] },
        "fileType": { "type": "string", "enum": ["PDF", "DOCX", "PPT", "Folder", "Video", "Lainnya"] },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isApproved": { "type": "boolean" },
        "rating": { "type": "number" },
        "ratingCount": { "type": "integer" }
      },
      "required": ["title", "description", "driveUrl", "category", "fileType", "authorId", "authorName", "createdAt", "isApproved"]
    },
    "BestPracticeComment": {
      "title": "Best Practice Comment",
      "description": "Comment on a specific best practice entry.",
      "type": "object",
      "properties": {
        "bestPracticeId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["bestPracticeId", "userId", "userName", "content", "createdAt"]
    },
    "BestPracticeMessage": {
      "title": "Best Practice Message",
      "description": "Chat message in the Best Practice section.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "message", "createdAt"]
    }
  },
  "firestore": {
    "profiles/{uid}": {
      "schema": "Profile",
      "description": "User profiles indexed by UID."
    },
    "news/{newsId}": {
      "schema": "News",
      "description": "News articles collection."
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "Events and workshops collection."
    },
    "materials/{materialId}": {
      "schema": "Material",
      "description": "Educational materials collection."
    },
    "staff/{staffId}": {
      "schema": "Staff",
      "description": "Organization staff members."
    },
    "settings/{settingId}": {
      "schema": "Settings",
      "description": "Global site settings."
    },
    "documentation/{docId}": {
      "schema": "Documentation",
      "description": "Activity documentation collection."
    },
    "best_practices/{bpId}": {
      "schema": "BestPractice",
      "description": "Best practices collection."
    },
    "best_practice_messages/{msgId}": {
      "schema": "BestPracticeMessage",
      "description": "Global chat messages for best practices."
    },
    "best_practice_comments/{commentId}": {
      "schema": "BestPracticeComment",
      "description": "Comments on specific best practices."
    }
  }
}
